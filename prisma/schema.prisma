generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  EXPERT
}

enum ApplicationStatus {
  TO_SEND
  SENT
  VIEWED
  INTERVIEW_SCHEDULED
  INTERVIEW_DONE
  OFFER_RECEIVED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum LetterTone {
  professional
  dynamic
  creative
}

// ─── User ───────────────────────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  avatar          String?
  phone           String?
  linkedinUrl     String?
  currentTitle    String?
  location        String?
  bio             String?
  targetSalary    String?
  targetContract  String[] @default([])
  targetSectors   String[] @default([])
  targetLocations String[] @default([])
  skills          String[] @default([])
  languages       String[] @default([])
  portfolio       String?
  availability    String?
  objectives      String?
  experiences     Json?
  formations      Json?
  workMode        String?
  companySize     String?
  companyType     String?
  travelWillingness    Boolean?
  relocationWillingness Boolean?
  plan            Plan     @default(FREE)
  emailVerified            Boolean   @default(false)
  emailVerificationToken   String?   @unique
  emailVerificationExpiry  DateTime?
  onboardingDone           Boolean   @default(false)

  stripeCustomerId     String? @unique
  stripeSubscriptionId String?

  notifEmailNewOffer          Boolean @default(true)
  notifEmailApplicationStatus Boolean @default(true)
  notifEmailWeeklyDigest      Boolean @default(false)

  deletionScheduledAt DateTime?
  deletionReason      String?

  supabaseId  String?  @unique

  adminLevel  Int?
  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  smtpHost    String?
  smtpPort    Int?
  smtpUser    String?
  smtpPassEnc String?
  smtpFrom    String?

  cvs              CV[]
  letters          CoverLetter[]
  applications     Application[]
  refreshTokens    RefreshToken[]
  dailyUsages      DailyUsage[]
  jobAlerts        JobAlert[]
  savedOffers      SavedOffer[]
  contactMessages  ContactMessage[]
  jobNotifications JobNotification[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── CV ─────────────────────────────────────────────────────────────

model CV {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  template  String   @default("modern")
  content   Json     @default("{}")
  pdfUrl    String?
  isDefault Boolean  @default(false)
  atsScore  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications Application[]

  @@index([userId])
  @@map("cvs")
}

// ─── Cover Letter ───────────────────────────────────────────────────

model CoverLetter {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String     @default("Sans titre")
  jobTitle    String?
  companyName String?
  content     String
  tone        LetterTone @default(professional)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  applications Application[]

  @@index([userId])
  @@map("cover_letters")
}

// ─── Application ────────────────────────────────────────────────────

model Application {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobOfferId   String?
  status       ApplicationStatus @default(TO_SEND)
  company      String
  jobTitle     String
  jobUrl       String?
  appliedAt    DateTime          @default(now())
  cvId         String?
  cv           CV?               @relation(fields: [cvId], references: [id], onDelete: SetNull)
  letterId     String?
  letter       CoverLetter?      @relation(fields: [letterId], references: [id], onDelete: SetNull)
  notes        String?
  nextStep     String?
  nextStepDate DateTime?
  contactEmail String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([userId])
  @@index([status])
  @@map("applications")
}

// ─── Daily Usage (quota tracking) ───────────────────────────────────────

model DailyUsage {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            String   // YYYY-MM-DD in user timezone
  cvGeneration    Int      @default(0)
  coverLetter     Int      @default(0)
  jobSearch       Int      @default(0)
  aiMatching      Int      @default(0)
  autoApply       Int      @default(0)
  interviewQuestions Int   @default(0)
  application     Int      @default(0)

  @@unique([userId, date])
  @@index([userId])
  @@map("daily_usages")
}

// ─── Job Alert ──────────────────────────────────────────────────────

model JobAlert {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywords  String
  location  String   @default("")
  frequency String   @default("daily")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("job_alerts")
}
// ─── Saved Offer ──────────────────────────────────────────────────────────────

model SavedOffer {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  offerId      String
  title        String
  company      String
  location     String   @default("")
  contractType String   @default("")
  salary       String?
  url          String?
  description  String?
  savedAt      DateTime @default(now())

  @@unique([userId, offerId])
  @@index([userId])
  @@map("saved_offers")
}

// ─── Contact Messages ─────────────────────────────────────────────────────────

model ContactMessage {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject      String
  message      String
  read         Boolean   @default(false)
  adminReply   String?
  repliedAt    DateTime?
  replyRead    Boolean   @default(false)
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@map("contact_messages")
}

// ─── Job Notification ──────────────────────────────────────────────────────────

model JobNotification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  offerId    String
  title      String
  company    String
  location   String   @default("")
  url        String?
  matchScore Int?
  read       Boolean  @default(false)
  detectedAt DateTime @default(now())

  @@unique([userId, offerId])
  @@index([userId])
  @@map("job_notifications")
}