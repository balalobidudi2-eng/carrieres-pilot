# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/carrieres_pilot?schema=public"

# ─── Auth (JWT) ──────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-random-64-char-secret"

# ─── OpenAI ──────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── France Travail API ──────────────────────────────────────────────
FRANCE_TRAVAIL_CLIENT_ID=""
FRANCE_TRAVAIL_CLIENT_SECRET=""

# ─── Stripe ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=""
NEXT_PUBLIC_STRIPE_EXPERT_PRICE_ID=""

# ─── SMTP (Email) ───────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Carrières Pilot <noreply@carrieres-pilot.fr>"

# ─── Google OAuth ────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Set Authorized redirect URI to: https://yourdomain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── App URL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
